---
// src/pages/admin/index.astro
import AdminApp from '../../components/admin/AdminApp';
import '../../styles/global.css';
---

<!doctype html>
<html lang="es" class="bg-black">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>MILODÓN • Sistema de Control</title>
  </head>
  <body class="bg-black text-slate-100 font-sans antialiased overflow-x-hidden">
    {/* client:only="react" es vital aquí porque AdminApp depende de window y 
        las APIs de Supabase que solo existen en el navegador [cite: 63, 79] */}
    <AdminApp client:only="react" />
  </body>
</html>

<style is:global>
  /* Personalización del scrollbar para el panel admin (estética técnica) */
  ::-webkit-scrollbar {
    width: 6px;
  }
  ::-webkit-scrollbar-track {
    background: #000000;
  }
  ::-webkit-scrollbar-thumb {
    background: #1e293b;
    border-radius: 10px;
  }
  ::-webkit-scrollbar-thumb:hover {
    background: #334155;
  }

  /* Animación de carga para transiciones entre secciones del Admin */
  .admin-fade-in {
    animation: adminFade 0.3s ease-out forwards;
  }

  @keyframes adminFade {
    from { opacity: 0; transform: scale(0.99); }
    to { opacity: 1; transform: scale(1); }
  }
</style>